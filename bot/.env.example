# ═══════════════════════════════════════════════════════════════════════════
# Telegram Calendar Task Manager — конфигурация
# Скопируй этот файл в .env, заполни значения. Все строки с # — комментарии.
# Большинство параметров можно менять прямо из бота через /settings.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Telegram ──────────────────────────────────────────────────────────────
# Получи токен у @BotFather в Telegram
BOT_TOKEN=

# Список Telegram user_id через запятую — кто может пользоваться ботом
# (узнать свой ID можно через @userinfobot)
ALLOWED_IDS=

# Опционально: единственный user_id, кому разрешено /settings, /reauth, /auth_code.
# По умолчанию — первый ID из ALLOWED_IDS. Защита от того что член семьи
# случайно сломает конфиг.
OWNER_ID=

# ─── LLM провайдер ─────────────────────────────────────────────────────────
# "groq" (быстрее, дешевле, рекомендую) или "google" (Gemini)
LLM_PROVIDER=groq

# Groq API: https://console.groq.com/keys
GROQ_API_KEY=
# Доступные модели смотри в /settings → AI или на console.groq.com
GROQ_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct

# Google AI Studio (используется только при LLM_PROVIDER=google)
# Ключ: https://aistudio.google.com/apikey
GOOGLE_AI_KEY=
GOOGLE_AI_MODEL=gemini-2.0-flash

# ─── Google Calendar / Tasks (OAuth) ───────────────────────────────────────
# 1. Создай OAuth client (Desktop app) в Google Cloud Console:
#    https://console.cloud.google.com/apis/credentials
# 2. В Authorized redirect URIs обязательно добавь: http://localhost
# 3. Скачай credentials.json и вставь его содержимое одной строкой ниже:
GOOGLE_CREDENTIALS_JSON=

# Токен авторизации (после первого /reauth заполняется автоматически).
# Если у тебя уже есть token.json от прошлой авторизации — можешь вставить
# его содержимое сюда, чтобы пропустить /reauth.
GOOGLE_TOKEN_JSON=

# Путь к файлу токена. Если GOOGLE_TOKEN_JSON пуст — токен читается отсюда.
GOOGLE_TOKEN_PATH=data/token.json

# ─── Часовой пояс ──────────────────────────────────────────────────────────
# IANA-имя зоны: Europe/Moscow, Asia/Almaty, Asia/Tashkent, Asia/Tbilisi и т.п.
# Полный список: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/Moscow

# ─── Расписание ────────────────────────────────────────────────────────────
# Время утреннего брифинга (HH:MM в локальной зоне TIMEZONE)
BRIEFING_TIME=08:00

# Интервал проверки дедлайнов (часы). Меньше = чаще напоминания.
REMINDER_INTERVAL_HOURS=1

# ─── Часы дня (для агента и фильтров) ──────────────────────────────────────
# 🟢 Рабочие часы — куда агент по умолчанию ставит встречи
WORK_HOUR_START=9
WORK_HOUR_END=20

# 🔴 Часы сна — встречи НЕ ставятся, напоминания тихие
SLEEP_HOUR_START=22
SLEEP_HOUR_END=7

# ─── Визуализация (хитмап + текстовые вью) ─────────────────────────────────
# Адаптивный диапазон Y хитмапа: clamp(min/max событий, [MIN, MAX])
HEATMAP_HOUR_MIN=6
HEATMAP_HOUR_MAX=24

# Минимальное "свободное окно" для подсветки (часы)
# для команды 🗓 Сегодня:
MIN_FREE_WINDOW_TODAY_HOURS=1.0
# для хитмапа недели:
MIN_FREE_WINDOW_HOURS=2.0

# Сроки задач: как красить дедлайны
# 🔴 если осталось ≤ N дней:
URGENT_TASK_DAYS=1
# 🟡 если 2..N дней, иначе 🟢:
WARM_TASK_DAYS=7

# Регексы рутинных событий через запятую (схлопываются на хитмапе и в "Сегодня")
ROUTINE_PATTERNS=Дорога

# Знаменатель для процента нагрузки (часов в неделю в активной деятельности)
WORK_HOURS_PER_WEEK=70

# ─── Логирование и БД ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
DB_PATH=data/bot.db

# Максимум записей в таблице bot_logs (лог в SQLite). 0 = не ограничивать.
LOG_DB_MAX_ROWS=10000

# Порт health-check сервера (DigitalOcean ставит сюда автоматически)
PORT=8080
