# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_IDS=123456789,987654321

# LLM провайдер: groq (default) или google
LLM_PROVIDER=groq

# Groq API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Google AI Studio (если LLM_PROVIDER=google)
GOOGLE_AI_KEY=
GOOGLE_AI_MODEL=gemini-2.0-flash

# Google OAuth — вставить содержимое credentials.json одной строкой
GOOGLE_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["urn:ietf:wg:oauth:2.0:oob","http://localhost"],...}}
# Токен авторизации — заполняется автоматически при /auth_code, или вставить вручную
GOOGLE_TOKEN_JSON=
# Путь к файлу токена (fallback и место записи при reauth)
GOOGLE_TOKEN_PATH=data/token.json

# Расписание
BRIEFING_TIME=08:00
REMINDER_INTERVAL_HOURS=1

# Рабочие и тихие часы (локальное время TIMEZONE)
WORK_HOUR_START=9
WORK_HOUR_END=20
SLEEP_HOUR_START=22
SLEEP_HOUR_END=7

# Временная зона (IANA: Europe/Moscow, Asia/Almaty, Asia/Tashkent, и т.д.)
TIMEZONE=UTC

# Логирование и база данных
LOG_LEVEL=INFO
DB_PATH=data/bot.db
