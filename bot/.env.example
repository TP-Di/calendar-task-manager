# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_IDS=123456789,987654321

# Groq API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google APIs
# Вставить содержимое credentials.json одной строкой (из Google Cloud Console → OAuth 2.0)
GOOGLE_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["urn:ietf:wg:oauth:2.0:oob","http://localhost"],...}}
# Вставить содержимое token.json после первой авторизации (опционально — иначе читается из файла)
GOOGLE_TOKEN_JSON=
# Файловый fallback для токена (используется если GOOGLE_TOKEN_JSON пустой)
GOOGLE_TOKEN_PATH=data/token.json

# Расписание
BRIEFING_TIME=08:00
REMINDER_INTERVAL_HOURS=1
QUIET_HOUR_START=23
QUIET_HOUR_END=6

# Логирование и база данных
LOG_LEVEL=INFO
DB_PATH=data/bot.db
